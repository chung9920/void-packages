pkgname=neuswc
version=0.0.20260523
revision=1
build_style=meson
configure_args="-Db_lundef=false -Dextra=true"
hostmakedepends="pkg-config"
makedepends="wayland-devel expat-devel libdrm-devel neuwld-devel pixman-devel wayland-protocols fontconfig-devel libxkbcommon-devel libinput-devel libxcb-devel xcb-util-wm-devel xorg-server-xwayland"
depends="wayland-protocols xorg-server-xwayland"
