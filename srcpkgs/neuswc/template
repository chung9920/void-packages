checksum=e6ee7894da3c76e26d71d9ecf270990eafc887507483124be03c34ad3fb0b167

post_install() {
	vlicense LICENSE
}

neuswc-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/libswc.a
		vmove usr/lib/pkgconfig
		vcopy build/protocol/*.h usr/include
	}
}
